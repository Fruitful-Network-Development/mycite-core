# Build context: /srv/repo/mycite-core/portals (via compose/portals docker-compose.yml)
#
# Keep images small and avoid shipping local venv/runtime artifacts.
.git
.flask-multi
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.mypy_cache

# Local portal venvs
**/.venv

# OS / editor noise (many tiny files slow down COPY on some filesystems)
**/.DS_Store
**/Thumbs.db

# Optional markdown under static icons (not needed at runtime)
assets/icons/**/*.md
